extend meta.type {
    func compileOnFrame(self, code, caller) frame(self.compile(code).bytecodes, caller.scope, caller);
    func compileOnScope(self, code, scope) frame(self.compile(code).bytecodes, scope);
    func compileFileOnFrame(self, file, caller) frame(self.compileFile(file).bytecodes, caller.scope, caller);
    func compileFileOnScope(self, file, scope) frame(self.compileFile(file).bytecodes, scope);
}